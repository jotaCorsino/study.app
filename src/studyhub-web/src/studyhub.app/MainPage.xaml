<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:components="clr-namespace:studyhub.app.Components"
             x:Class="studyhub.app.MainPage"
             BackgroundColor="#0D0F14">

    <AbsoluteLayout x:Name="rootLayout">
        <BlazorWebView x:Name="blazorWebView"
                       HostPage="wwwroot/index.html"
                       AbsoluteLayout.LayoutBounds="0,0,1,1"
                       AbsoluteLayout.LayoutFlags="All">
            <BlazorWebView.RootComponents>
                <RootComponent Selector="#app" ComponentType="{x:Type components:Routes}" />
            </BlazorWebView.RootComponents>
        </BlazorWebView>

        <Grid x:Name="nativePlayerHost"
              IsVisible="False"
              BackgroundColor="Black"
              ZIndex="10"
              AbsoluteLayout.LayoutBounds="0,0,0,0"
              AbsoluteLayout.LayoutFlags="None">
            <toolkit:MediaElement x:Name="nativeMediaElement"
                                  Aspect="AspectFit"
                                  BackgroundColor="Black"
                                  ShouldAutoPlay="False"
                                  ShouldShowPlaybackControls="True" />

            <Border x:Name="nativePlayerStatusOverlay"
                    IsVisible="False"
                    InputTransparent="True"
                    Margin="16"
                    Padding="12,10"
                    HorizontalOptions="Fill"
                    VerticalOptions="End"
                    BackgroundColor="#CC0A0C10"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="2">
                    <Label x:Name="nativePlayerStatusTitle"
                           TextColor="White"
                           FontSize="12"
                           FontAttributes="Bold" />
                    <Label x:Name="nativePlayerStatusMessage"
                           TextColor="#C7FFFFFF"
                           FontSize="11"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid x:Name="externalPlayerHost"
              IsVisible="False"
              BackgroundColor="Black"
              ZIndex="11"
              AbsoluteLayout.LayoutBounds="0,0,0,0"
              AbsoluteLayout.LayoutFlags="None">
            <WebView x:Name="externalPlayerWebView"
                     BackgroundColor="Black" />

            <Border x:Name="externalPlayerStatusOverlay"
                    IsVisible="False"
                    InputTransparent="True"
                    Margin="16"
                    Padding="12,10"
                    HorizontalOptions="Fill"
                    VerticalOptions="End"
                    BackgroundColor="#CC0A0C10"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="2">
                    <Label x:Name="externalPlayerStatusTitle"
                           TextColor="White"
                           FontSize="12"
                           FontAttributes="Bold" />
                    <Label x:Name="externalPlayerStatusMessage"
                           TextColor="#C7FFFFFF"
                           FontSize="11"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </AbsoluteLayout>

</ContentPage>
