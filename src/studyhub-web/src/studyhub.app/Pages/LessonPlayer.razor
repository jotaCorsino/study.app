@page "/course/{CourseId:guid}/lesson/{LessonId:guid}"
@layout studyhub.app.Components.Layout.MainLayout
@using System.Globalization
@using Microsoft.Extensions.Logging
@using Microsoft.JSInterop
@using studyhub.app.services
@using studyhub.application.Interfaces
@using studyhub.domain.Entities
@using studyhub.shared.Enums
@using studyhub.app.Components.Course
@using studyhub.app.Components.Shared
@implements IDisposable
@inject ICourseService CourseService
@inject IProgressService ProgressService
@inject ExternalLessonPlaybackService ExternalPlaybackService
@inject IJSRuntime JS
@inject ILogger<LessonPlayer> Logger
@inject NavigationManager nav

<div class="player-layout">
    @if (isLoading)
    {
        <div class="flex-1 flex justify-center items-center">
            <div class="text-tertiary">Carregando aula...</div>
        </div>
    }
    else if (course == null || currentLesson == null)
    {
        <div class="flex-1 flex flex-col items-center justify-center">
            <div class="empty-state-icon-shell mb-md">
                <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="15" y1="9" x2="9" y2="15"></line>
                    <line x1="9" y1="9" x2="15" y2="15"></line>
                </svg>
            </div>
            <h3 class="text-lg font-medium mb-xs">Aula não encontrada</h3>
            <button class="btn btn-secondary mt-md" @onclick='() => nav.NavigateTo($"/course/{CourseId}")'>Voltar para o curso</button>
        </div>
    }
    else
    {
        <div class="player-main">
            <div class="player-lesson-header">
            <Breadcrumb Items="breadcrumbItems" />
            <h1 class="player-lesson-title">@currentLesson.Title</h1>
            <div class="player-lesson-meta">
                <span class="player-lesson-meta-tag">@currentModule?.Title</span>
                <span class="player-lesson-meta-sep">›</span>
                <span class="player-lesson-meta-topic">@currentTopic?.Title</span>
            </div>
        </div>

            <div class="player-video-area">
                <LessonPlaybackHost @key="@($"{LessonId}:{currentLesson.SourceType}")"
                                    CourseId="CourseId"
                                    Lesson="currentLesson"
                                    LocalInitialStartOffset="localInitialStartOffset"
                                    ExternalInitialStartOffset="externalInitialStartOffset"
                                    RequestedPlaybackSpeed="selectedPlaybackSpeed"
                                    OnLessonCompleted="HandleLessonCompletedAsync" />
            </div>
            
            <div class="player-controls">
                <div class="player-controls-nav player-controls-nav-left">
                    <button class="btn btn-secondary player-ctrl-btn" @onclick="GoToPreviousLesson" disabled="@(previousLesson == null)">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
                        <span>Aula anterior</span>
                    </button>
                    @if (IsLessonCompleted())
                    {
                        <button class="btn player-ctrl-btn player-ctrl-done">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            <span>Aula concluída</span>
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-secondary player-ctrl-btn hover:border-success hover:text-success" @onclick="MarkAsCompleted">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                            <span>Marcar como concluída</span>
                        </button>
                    }
                </div>

                <div class="player-controls-settings">
                    <div class="player-settings-inline-slot">
                        @if (settingsInlineMode == PlayerControlsSettingsMode.Normal)
                        {
                            <div class="player-settings-normal-actions">
                                <button type="button"
                                        class="player-control-icon-btn"
                                        title="Velocidade"
                                        aria-label="Velocidade de reproducao"
                                        @onclick="OpenSpeedInlineSettings">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="5 7 10 12 5 17"></polyline>
                                        <polyline points="12 7 17 12 12 17"></polyline>
                                        <line x1="19" y1="7" x2="19" y2="17"></line>
                                    </svg>
                                </button>

                                <button type="button"
                                        class="player-control-icon-btn player-control-icon-btn-intro @(introSkipEnabled ? "is-active" : string.Empty)"
                                        title="Intro skip"
                                        aria-label="Configurar intro skip"
                                        @onclick="OpenIntroInlineSettings">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round">
                                        <polygon points="5 4 13 12 5 20 5 4"></polygon>
                                        <line x1="16" y1="5" x2="16" y2="19"></line>
                                    </svg>
                                </button>
                            </div>
                        }
                        else if (settingsInlineMode == PlayerControlsSettingsMode.SpeedInline)
                        {
                            <div class="player-settings-inline-panel player-settings-inline-panel-speed"
                                 role="group"
                                 aria-label="Selecionar velocidade">
                                <span class="player-settings-inline-title">Vel. Reproducao</span>

                                <div class="player-inline-speed-options">
                                    @foreach (var speed in availablePlaybackSpeeds)
                                    {
                                        <button type="button"
                                                class="player-inline-speed-btn @(Math.Abs(selectedPlaybackSpeed - speed) < 0.0001 ? "active" : string.Empty)"
                                                @onclick="() => SelectPlaybackSpeed(speed)">
                                            @FormatPlaybackSpeed(speed)
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                        else if (settingsInlineMode == PlayerControlsSettingsMode.IntroInline)
                        {
                            <div class="player-settings-inline-panel player-settings-inline-panel-intro"
                                 role="group"
                                 aria-label="Configurar intro skip">
                                <span class="player-settings-inline-title">Intro Skip</span>

                                <label class="player-switch-control player-switch-control-inline" for="lesson-player-intro-skip-enabled">
                                    <input id="lesson-player-intro-skip-enabled"
                                           type="checkbox"
                                           class="player-switch-input"
                                           checked="@introSkipEnabled"
                                           disabled="@isSavingIntroSkipPreference"
                                           @onchange="HandleIntroSkipEnabledChangedAsync" />
                                    <span class="player-switch-track" aria-hidden="true">
                                        <span class="player-switch-thumb"></span>
                                    </span>
                                </label>

                                <div class="player-inline-intro-seconds-group">
                                    <input id="lesson-player-intro-skip-seconds"
                                           class="player-speed-select player-speed-select--intro player-inline-intro-input"
                                           type="number"
                                           min="0"
                                           step="1"
                                           inputmode="numeric"
                                           value="@introSkipInput"
                                           disabled="@isSavingIntroSkipPreference"
                                           @onchange="HandleIntroSkipSecondsChangedAsync" />
                                    <span class="player-inline-intro-seconds-suffix">s</span>
                                </div>

                                <button type="button"
                                        class="player-inline-close-btn"
                                        title="Fechar"
                                        aria-label="Fechar configuracao de intro skip"
                                        @onclick="CloseInlineSettings">
                                    x
                                </button>

                                @if (isSavingIntroSkipPreference)
                                {
                                    <span class="player-speed-effective-hint player-speed-effective-hint-inline-panel">Salvando...</span>
                                }
                                else if (!string.IsNullOrWhiteSpace(introSkipSaveError))
                                {
                                    <span class="player-speed-effective-hint player-speed-effective-hint-inline-panel">@introSkipSaveError</span>
                                }
                            </div>
                        }
                    </div>

                    @if (ShouldShowExternalPlaybackFallback)
                    {
                        <span class="player-speed-effective-hint player-speed-effective-hint-inline">
                            YouTube aplicou @FormatPlaybackSpeed(externalPlaybackSnapshot.EffectivePlaybackSpeed)
                            (solicitado @FormatPlaybackSpeed(externalPlaybackSnapshot.RequestedPlaybackSpeed)).
                        </span>
                    }
                </div>

                <div class="player-controls-nav player-controls-nav-right">
                    <button class="btn btn-primary player-ctrl-btn" @onclick="GoToNextLesson" disabled="@(nextLesson == null)">
                        <span>Próxima aula</span>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"></polyline></svg>
                    </button>
                </div>
            </div>
        </div>
        
        <div class="player-sidebar" id="@SidebarElementId">
            <div class="player-sidebar-header flex justify-between items-center">
                <span>Conteúdo do curso</span>
                <button class="btn-icon" @onclick='() => nav.NavigateTo($"/course/{CourseId}")'>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>
            
            <div class="player-sidebar-body">
                @if (course.Modules != null)
                {
                    var moduleNumber = 1;
                    @foreach (var module in course.Modules.OrderBy(m => m.Order))
                    {
                        var hasActiveLesson = module.Topics?.Any(t => t.Lessons?.Any(l => l.Id == LessonId) ?? false) ?? false;
                        
                        <ModuleAccordion 
                            ModuleNumber="moduleNumber" 
                            Module="@module" 
                            LessonStatuses="@lessonStatuses"
                            ActiveLessonId="@LessonId"
                            IsOpen="@hasActiveLesson"
                            EnableInternalScroll="true"
                            OnLessonSelected="NavigateToLesson" />
                        moduleNumber++;
                    }
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid CourseId { get; set; }
    [Parameter] public Guid LessonId { get; set; }
    
    private Course? course;
    private Module? currentModule;
    private Topic? currentTopic;
    private Lesson? currentLesson;
    private Lesson? previousLesson;
    private Lesson? nextLesson;
    
    private Progress? progress;
    private bool isLoading = true;
    private List<Breadcrumb.BreadcrumbItem> breadcrumbItems = new();
    private Dictionary<Guid, LessonStatus> lessonStatuses = new();
    private Guid? pendingSidebarAnchorLessonId;
    private Guid? lastAppliedSidebarAnchorLessonId;
    private const string SidebarElementId = "lesson-player-sidebar";
    private const double DefaultPlaybackSpeed = 1.0;
    private const int DefaultIntroSkipSeconds = 0;
    private static readonly double[] availablePlaybackSpeeds = [0.5, 1.0, 1.5, 2.0, 2.5];
    private double selectedPlaybackSpeed = DefaultPlaybackSpeed;
    private bool introSkipEnabled;
    private int introSkipSeconds = DefaultIntroSkipSeconds;
    private string introSkipInput = DefaultIntroSkipSeconds.ToString(CultureInfo.InvariantCulture);
    private bool isSavingIntroSkipPreference;
    private string introSkipSaveError = string.Empty;
    private PlayerControlsSettingsMode settingsInlineMode = PlayerControlsSettingsMode.Normal;
    private TimeSpan localInitialStartOffset = TimeSpan.Zero;
    private TimeSpan externalInitialStartOffset = TimeSpan.Zero;
    private ExternalLessonPlaybackSnapshot externalPlaybackSnapshot = ExternalLessonPlaybackSnapshot.Hidden;

    private enum PlayerControlsSettingsMode
    {
        Normal,
        SpeedInline,
        IntroInline
    }

    private bool ShouldShowExternalPlaybackFallback =>
        currentLesson?.SourceType == LessonSourceType.ExternalVideo &&
        currentLesson.Id != Guid.Empty &&
        externalPlaybackSnapshot.SessionToken != 0 &&
        externalPlaybackSnapshot.LessonId == currentLesson.Id &&
        externalPlaybackSnapshot.Status != ExternalLessonPlaybackStatus.Error &&
        Math.Abs(externalPlaybackSnapshot.RequestedPlaybackSpeed - externalPlaybackSnapshot.EffectivePlaybackSpeed) >= 0.01;

    protected override void OnInitialized()
    {
        externalPlaybackSnapshot = ExternalPlaybackService.Snapshot;
        ExternalPlaybackService.StateChanged += HandleExternalPlaybackStateChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await ApplyPendingSidebarAnchorAsync();
    }

    private async Task ApplyPendingSidebarAnchorAsync()
    {
        if (!pendingSidebarAnchorLessonId.HasValue ||
            isLoading ||
            currentLesson == null)
        {
            return;
        }

        var anchorLessonId = pendingSidebarAnchorLessonId.Value;
        pendingSidebarAnchorLessonId = null;

        try
        {
            var scrolled = await JS.InvokeAsync<bool>(
                "studyHubLessonSidebar.scrollToLesson",
                SidebarElementId,
                anchorLessonId.ToString());

            if (scrolled)
            {
                lastAppliedSidebarAnchorLessonId = anchorLessonId;
            }
            else
            {
                Logger.LogWarning(
                    "Lesson sidebar anchor target was not found. CourseId: {CourseId}. LessonId: {LessonId}.",
                    CourseId,
                    anchorLessonId);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(
                ex,
                "Lesson sidebar scroll anchoring failed. CourseId: {CourseId}. LessonId: {LessonId}.",
                CourseId,
                anchorLessonId);
        }
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        await ProgressService.OpenLessonAsync(CourseId, LessonId);
        await LoadSnapshotAsync();
        
        isLoading = false;
        StateHasChanged();
    }

    private async Task LoadSnapshotAsync()
    {
        lessonStatuses = new Dictionary<Guid, LessonStatus>();
        currentModule = null;
        currentTopic = null;
        currentLesson = null;
        previousLesson = null;
        nextLesson = null;
        breadcrumbItems = new List<Breadcrumb.BreadcrumbItem>();
        ResetIntroSkipPreferenceState();

        course = await CourseService.GetCourseByIdAsync(CourseId);
        progress = null;

        if (course == null)
        {
            return;
        }

        ApplyIntroSkipPreferenceFromCourse(course);

        if (course.Modules == null)
        {
            return;
        }

        progress = await ProgressService.GetProgressByCourseAsync(CourseId);
        FindCurrentContext();
        UpdateInitialStartOffsets();

        if (currentLesson == null)
        {
            return;
        }

        if (lastAppliedSidebarAnchorLessonId != currentLesson.Id)
        {
            pendingSidebarAnchorLessonId = currentLesson.Id;
        }

        breadcrumbItems = new List<Breadcrumb.BreadcrumbItem>
        {
            new Breadcrumb.BreadcrumbItem("Catálogo", "/"),
            new Breadcrumb.BreadcrumbItem(course.Title, $"/course/{CourseId}"),
            new Breadcrumb.BreadcrumbItem(currentLesson.Title)
        };

        BuildLessonStatuses();
    }

    private void FindCurrentContext()
    {
        if (course?.Modules == null) return;
        
        var flatLessons = new List<Lesson>();
        var lessonsToCtx = new Dictionary<Guid, (Module m, Topic t)>();

        foreach (var module in course.Modules.OrderBy(m => m.Order))
        {
            if (module.Topics == null) continue;
            foreach (var topic in module.Topics.OrderBy(t => t.Order))
            {
                if (topic.Lessons == null) continue;
                foreach (var lesson in topic.Lessons.OrderBy(l => l.Order))
                {
                    flatLessons.Add(lesson);
                    lessonsToCtx[lesson.Id] = (module, topic);
                }
            }
        }

        var index = flatLessons.FindIndex(lesson => lesson.Id == LessonId);
        if (index >= 0)
        {
            currentLesson = flatLessons[index];
            var ctx = lessonsToCtx[LessonId];
            currentModule = ctx.m;
            currentTopic = ctx.t;
            previousLesson = index - 1 >= 0 ? flatLessons[index - 1] : null;
            nextLesson = index + 1 < flatLessons.Count ? flatLessons[index + 1] : null;
        }
    }

    private void BuildLessonStatuses()
    {
        lessonStatuses = new Dictionary<Guid, LessonStatus>();

        if (course?.Modules == null) return;

        foreach (var module in course.Modules.OrderBy(m => m.Order))
        {
            if (module.Topics == null) continue;
            foreach (var topic in module.Topics.OrderBy(t => t.Order))
            {
                if (topic.Lessons == null) continue;
                foreach (var lesson in topic.Lessons.OrderBy(l => l.Order))
                {
                    lessonStatuses[lesson.Id] = lesson.Status;
                }
            }
        }
    }

    private bool IsLessonCompleted()
    {
        return lessonStatuses.TryGetValue(LessonId, out var status) && status == LessonStatus.Completed;
    }

    private async Task MarkAsCompleted()
    {
        if (IsLessonCompleted()) return;
        
        await ProgressService.MarkLessonCompletedAsync(CourseId, LessonId);
        await LoadDataAsync();
    }

    private async Task HandleLessonCompletedAsync()
    {
        await LoadDataAsync();
    }

    private void GoToPreviousLesson()
    {
        if (previousLesson != null)
        {
            NavigateToLesson(previousLesson);
        }
    }

    private void GoToNextLesson()
    {
        if (nextLesson != null)
        {
            NavigateToLesson(nextLesson);
        }
    }

    private void NavigateToLesson(Lesson lesson)
    {
        CloseInlineSettings();
        nav.NavigateTo($"/course/{CourseId}/lesson/{lesson.Id}");
    }

    private void OpenSpeedInlineSettings()
    {
        settingsInlineMode = PlayerControlsSettingsMode.SpeedInline;
    }

    private void OpenIntroInlineSettings()
    {
        settingsInlineMode = PlayerControlsSettingsMode.IntroInline;
    }

    private void CloseInlineSettings()
    {
        settingsInlineMode = PlayerControlsSettingsMode.Normal;
    }

    private void SelectPlaybackSpeed(double speed)
    {
        selectedPlaybackSpeed = NormalizePlaybackSpeed(speed);
        settingsInlineMode = PlayerControlsSettingsMode.Normal;
    }

    private void ResetIntroSkipPreferenceState()
    {
        introSkipEnabled = false;
        introSkipSeconds = DefaultIntroSkipSeconds;
        introSkipInput = DefaultIntroSkipSeconds.ToString(CultureInfo.InvariantCulture);
        isSavingIntroSkipPreference = false;
        introSkipSaveError = string.Empty;
        settingsInlineMode = PlayerControlsSettingsMode.Normal;
        localInitialStartOffset = TimeSpan.Zero;
        externalInitialStartOffset = TimeSpan.Zero;
    }

    private void ApplyIntroSkipPreferenceFromCourse(Course loadedCourse)
    {
        introSkipEnabled = loadedCourse.SourceMetadata.IntroSkipEnabled;
        introSkipSeconds = NormalizeIntroSkipSeconds(loadedCourse.SourceMetadata.IntroSkipSeconds);
        introSkipInput = introSkipSeconds.ToString(CultureInfo.InvariantCulture);
        introSkipSaveError = string.Empty;
    }

    private async Task HandleIntroSkipEnabledChangedAsync(ChangeEventArgs args)
    {
        introSkipEnabled = ParseBoolean(args.Value);
        await PersistIntroSkipPreferenceAsync();
    }

    private async Task HandleIntroSkipSecondsChangedAsync(ChangeEventArgs args)
    {
        var normalizedSeconds = ParseIntroSkipSeconds(args.Value?.ToString());
        introSkipSeconds = normalizedSeconds;
        introSkipInput = normalizedSeconds.ToString(CultureInfo.InvariantCulture);
        await PersistIntroSkipPreferenceAsync();
    }

    private async Task PersistIntroSkipPreferenceAsync()
    {
        if (isSavingIntroSkipPreference)
        {
            return;
        }

        isSavingIntroSkipPreference = true;
        introSkipSaveError = string.Empty;

        try
        {
            var updatedMetadata = await CourseService.UpdateCourseIntroSkipPreferenceAsync(
                CourseId,
                introSkipEnabled,
                introSkipSeconds);

            if (updatedMetadata == null)
            {
                introSkipSaveError = "Nao foi possivel salvar.";
                return;
            }

            introSkipEnabled = updatedMetadata.IntroSkipEnabled;
            introSkipSeconds = NormalizeIntroSkipSeconds(updatedMetadata.IntroSkipSeconds);
            introSkipInput = introSkipSeconds.ToString(CultureInfo.InvariantCulture);

            if (course != null)
            {
                course.SourceMetadata.IntroSkipEnabled = introSkipEnabled;
                course.SourceMetadata.IntroSkipSeconds = introSkipSeconds;
            }

            UpdateInitialStartOffsets();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(
                ex,
                "Intro skip preference update failed. CourseId: {CourseId}.",
                CourseId);
            introSkipSaveError = "Nao foi possivel salvar.";
        }
        finally
        {
            isSavingIntroSkipPreference = false;
        }
    }

    private static int ParseIntroSkipSeconds(string? rawValue)
    {
        if (!int.TryParse(rawValue, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsedValue) &&
            !int.TryParse(rawValue, NumberStyles.Integer, CultureInfo.CurrentCulture, out parsedValue))
        {
            return DefaultIntroSkipSeconds;
        }

        return NormalizeIntroSkipSeconds(parsedValue);
    }

    private static int NormalizeIntroSkipSeconds(int seconds)
    {
        return seconds < 0 ? 0 : seconds;
    }

    private void UpdateInitialStartOffsets()
    {
        localInitialStartOffset = LessonInitialStartOffsetCalculator.ResolveForLesson(
            currentLesson,
            LessonSourceType.LocalFile,
            introSkipEnabled,
            introSkipSeconds);

        externalInitialStartOffset = LessonInitialStartOffsetCalculator.ResolveForLesson(
            currentLesson,
            LessonSourceType.ExternalVideo,
            introSkipEnabled,
            introSkipSeconds);
    }

    private static bool ParseBoolean(object? rawValue)
    {
        return rawValue switch
        {
            bool boolValue => boolValue,
            string stringValue when bool.TryParse(stringValue, out var parsedValue) => parsedValue,
            _ => false
        };
    }

    private static double NormalizePlaybackSpeed(double speed)
    {
        foreach (var supportedSpeed in availablePlaybackSpeeds)
        {
            if (Math.Abs(supportedSpeed - speed) < 0.0001)
            {
                return supportedSpeed;
            }
        }

        return DefaultPlaybackSpeed;
    }

    private static string FormatPlaybackSpeed(double speed)
    {
        return $"{speed.ToString("0.0##", CultureInfo.InvariantCulture)}x";
    }

    private void HandleExternalPlaybackStateChanged(ExternalLessonPlaybackSnapshot snapshot)
    {
        _ = InvokeAsync(() =>
        {
            externalPlaybackSnapshot = snapshot;
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        ExternalPlaybackService.StateChanged -= HandleExternalPlaybackStateChanged;
    }

    private string GetLessonReference()
    {
        if (currentLesson == null)
        {
            return string.Empty;
        }

        return currentLesson.SourceType == LessonSourceType.ExternalVideo
            ? currentLesson.ExternalUrl
            : currentLesson.FilePath;
    }
}
