@page "/course/{CourseId:guid}/roadmap"
@using studyhub.application.Interfaces
@using studyhub.domain.Entities
@using studyhub.app.Components.Roadmap
@using studyhub.app.Components.Shared
@inject ICourseService CourseService
@inject IRoadmapService RoadmapService
@inject NavigationManager nav

<div class="page-container">
    @if (isLoading)
    {
        <div class="flex justify-center items-center py-2xl">
            <div class="text-tertiary">Carregando roadmap...</div>
        </div>
    }
    else if (course == null)
    {
        <div class="flex flex-col items-center justify-center py-2xl">
            <div class="empty-state-icon-shell mb-md">
                <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="15" y1="9" x2="9" y2="15"></line>
                    <line x1="9" y1="9" x2="15" y2="15"></line>
                </svg>
            </div>
            <h3 class="text-lg font-medium mb-xs">Curso não encontrado</h3>
            <button class="btn btn-secondary mt-md" @onclick='() => nav.NavigateTo("/")'>Voltar para o catálogo</button>
        </div>
    }
    else
    {
        <Breadcrumb Items="breadcrumbItems" />

        <div class="roadmap-toolbar mb-lg">
            <button class="btn btn-secondary" @onclick='() => nav.NavigateTo($"/course/{CourseId}")'>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                <span>Voltar</span>
            </button>

            <button class="btn btn-secondary" @onclick="RegenerateRoadmapAsync" disabled="@isRegenerating">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2v6h-6"></path><path d="M3 12a9 9 0 0 1 15-6.7L21 8"></path><path d="M3 22v-6h6"></path><path d="M21 12a9 9 0 0 1-15 6.7L3 16"></path></svg>
                <span>@(isRegenerating ? "Gerando..." : "Regenerar roadmap")</span>
            </button>
        </div>

        <div class="page-header roadmap-page-header">
            <div class="roadmap-page-heading">
                <div class="flex items-center gap-sm mb-xs">
                    <span class="text-xs font-semibold text-accent uppercase tracking-wider">MAPA DE ESTUDO POR IA</span>
                    <span class="text-xs px-sm py-xs rounded text-warning" style="background-color: rgba(253, 203, 110, 0.1);">EXPERIMENTAL</span>
                </div>
                <h1>Roadmap: @course.Title</h1>
                <p class="page-subtitle">Um caminho de estudo otimizado e focado nas suas metas, gerado por inteligência artificial.</p>
            </div>

            <div class="roadmap-header-progress">
                <span class="roadmap-header-progress-label">Progresso geral</span>
                <div class="roadmap-header-progress-value">@GlobalProgress%</div>
            </div>
        </div>

        @if (roadmapLevels.Count == 0)
        {
            <div class="p-xl bg-surface border border-subtle rounded-xl text-center">
                <p class="text-secondary">Nenhum roadmap gerado para este curso ainda.</p>
                <button class="btn btn-primary mt-md" @onclick="RegenerateRoadmapAsync" disabled="@isRegenerating">
                    <span>@(isRegenerating ? "Gerando..." : "Gerar roadmap")</span>
                </button>
            </div>
        }
        else
        {
            <div class="max-w-4xl mt-lg pb-2xl">
                @foreach (var level in roadmapLevels.OrderBy(level => level.Order))
                {
                    <studyhub.app.Components.Roadmap.RoadmapLevel Level="@level" OnProgressChanged="HandleProgressUpdate" />
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public Guid CourseId { get; set; }

    private Course? course;
    private List<studyhub.domain.Entities.RoadmapLevel> roadmapLevels = [];
    private bool isLoading = true;
    private bool isRegenerating;
    private List<Breadcrumb.BreadcrumbItem> breadcrumbItems = new();

    private int GlobalProgress
        => roadmapLevels.Count == 0 ? 0 : (int)roadmapLevels.Average(level => level.OverallProgress);

    protected override async Task OnParametersSetAsync()
    {
        // O ROADMAP ESTÁ CONGELADO NESTA FASE. REDIRECIONAR.
        nav.NavigateTo($"/course/{CourseId}");
        
        await LoadRoadmapAsync();
    }

    private async Task LoadRoadmapAsync()
    {
        isLoading = true;
        course = await CourseService.GetCourseByIdAsync(CourseId);
        roadmapLevels = [];
        breadcrumbItems = new List<Breadcrumb.BreadcrumbItem>();

        if (course != null)
        {
            roadmapLevels = await RoadmapService.GetRoadmapByCourseAsync(CourseId);

            breadcrumbItems = new List<Breadcrumb.BreadcrumbItem>
            {
                new Breadcrumb.BreadcrumbItem("Catálogo", "/"),
                new Breadcrumb.BreadcrumbItem(course.Title, $"/course/{CourseId}"),
                new Breadcrumb.BreadcrumbItem("Roadmap de IA")
            };
        }

        isLoading = false;
    }

    private async Task HandleProgressUpdate()
    {
        await RoadmapService.SaveRoadmapAsync(CourseId, roadmapLevels);
        StateHasChanged();
    }

    private async Task RegenerateRoadmapAsync()
    {
        isRegenerating = true;
        await RoadmapService.GenerateRoadmapAsync(CourseId);
        roadmapLevels = await RoadmapService.GetRoadmapByCourseAsync(CourseId);
        isRegenerating = false;
        StateHasChanged();
    }
}
