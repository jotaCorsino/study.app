@page "/course/{CourseId:guid}/materials"
@using studyhub.application.Interfaces
@using studyhub.domain.Entities
@using studyhub.app.Components.Materials
@using studyhub.app.Components.Shared
@inject ICourseService CourseService
@inject IMaterialService MaterialService
@inject NavigationManager nav

<div class="page-container">
    @if (isLoading)
    {
        <div class="flex justify-center items-center py-2xl">
            <div class="text-tertiary">Carregando curadoria de materiais...</div>
        </div>
    }
    else if (course == null)
    {
        <div class="flex flex-col items-center justify-center py-2xl">
            <div class="empty-state-icon-shell mb-md">
                <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="15" y1="9" x2="9" y2="15"></line>
                    <line x1="9" y1="9" x2="15" y2="15"></line>
                </svg>
            </div>
            <h3 class="text-lg font-medium mb-xs">Curso nÃ£o encontrado</h3>
            <button class="btn btn-secondary mt-md" @onclick='() => nav.NavigateTo("/")'>Voltar para o catÃ¡logo</button>
        </div>
    }
    else
    {
        <Breadcrumb Items="breadcrumbItems" />
        
        <div class="page-header mb-xl flex flex-col items-start border-b border-subtle pb-md">
            <div class="flex items-center gap-sm mb-xs">
                <span class="text-xs font-semibold text-accent uppercase tracking-wider">CURADORIA AUTOMÃTICA</span>
                <span class="text-xs px-sm py-xs rounded text-success" style="background-color: rgba(0, 184, 148, 0.1);">FONTE VERIFICADA</span>
            </div>
            <div class="flex items-center gap-md">
                <button class="btn btn-secondary" @onclick='() => nav.NavigateTo($"/course/{CourseId}")'>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                    <span>Voltar</span>
                </button>
                <div>
                    <h1>Materiais extras: @course.Title</h1>
                    <p class="page-subtitle mb-0">Curadoria automÃ¡tica de conteÃºdo gratuito para complementar seus estudos.</p>
                </div>
            </div>
        </div>

        @if (materials.Count == 0)
        {
            <div class="p-xl bg-surface border border-subtle rounded-xl text-center">
                <p class="text-secondary mb-md">Ainda nÃ£o encontramos materiais complementares com score alto de relevÃ¢ncia.</p>
                <button class="btn btn-secondary mt-md" @onclick="GenerateMaterialsAsync" disabled="@isGeneratingMaterials">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                    <span>Gerar conteÃºdo complementar</span>
                </button>
            </div>
        }
        else
        {
            <div class="grid grid-cols-3 gap-xl pb-2xl">
                @foreach (var curr in materials.OrderByDescending(material => material.RelevanceScore))
                {
                    <MaterialCard Item="@curr" />
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public Guid CourseId { get; set; }
    
    private Course? course;
    private List<Material> materials = [];
    private bool isLoading = true;
    private bool isGeneratingMaterials;
    private List<Breadcrumb.BreadcrumbItem> breadcrumbItems = new();

    protected override async Task OnParametersSetAsync()
    {
        await LoadMaterialsAsync();
    }

    private async Task LoadMaterialsAsync()
    {
        isLoading = true;
        course = await CourseService.GetCourseByIdAsync(CourseId);
        materials = [];
        breadcrumbItems = new List<Breadcrumb.BreadcrumbItem>();
        
        if (course != null)
        {
            materials = await MaterialService.GetMaterialsByCourseAsync(CourseId);
            
            breadcrumbItems = new List<Breadcrumb.BreadcrumbItem>
            {
                new Breadcrumb.BreadcrumbItem("CatÃ¡logo", "/"),
                new Breadcrumb.BreadcrumbItem(course.Title, $"/course/{CourseId}"),
                new Breadcrumb.BreadcrumbItem("Materiais curados")
            };
        }
        
        isLoading = false;
    }

    private async Task GenerateMaterialsAsync()
    {
        if (course == null || isGeneratingMaterials)
        {
            return;
        }

        isGeneratingMaterials = true;
        try
        {
            await MaterialService.RefreshMaterialsAsync(CourseId);
            await LoadMaterialsAsync();
        }
        finally
        {
            isGeneratingMaterials = false;
            await InvokeAsync(StateHasChanged);
        }
    }
}
