@using studyhub.domain.Entities

<div class="roadmap-stage mb-lg">
    <div class="roadmap-stage-card bg-surface border @GetBorderClass() rounded-xl overflow-hidden transition-all duration-300">

        <div class="roadmap-stage-header p-md cursor-pointer hover:bg-elevated transition-colors" @onclick="ToggleAccordion">
            <div class="flex items-center justify-between mb-sm">
                <span class="text-xs font-bold text-accent uppercase tracking-wider">@Stage.Kicker</span>
                @if (Stage.Progress == 100)
                {
                    <span class="text-xs px-sm py-xs bg-success text-white rounded-md font-medium">CONCLUÍDO</span>
                }
                else if (Stage.Progress > 0)
                {
                    <span class="text-xs px-sm py-xs bg-accent text-white rounded-md font-medium">EM ANDAMENTO</span>
                }
            </div>

            <div class="flex justify-between items-center">
                <div>
                    <h3 class="text-lg font-bold text-primary m-0">@Stage.Title</h3>
                    <p class="text-sm text-secondary mt-xs mb-0">@Stage.Subtitle</p>
                </div>

                <div class="flex items-center gap-md">
                    <div class="relative w-10 h-10 flex items-center justify-center">
                        <svg class="w-full h-full transform -rotate-90" viewBox="0 0 36 36">
                            <path class="text-elevated stroke-current" stroke-width="3" fill="none" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                            <path class="text-accent stroke-current" stroke-dasharray="@Stage.Progress, 100" stroke-width="3" fill="none" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                        </svg>
                        <span class="absolute text-[10px] font-bold text-primary">@Stage.Progress%</span>
                    </div>

                    <svg class="roadmap-stage-chevron @(IsOpen ? "is-open" : string.Empty)" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                </div>
            </div>
        </div>

        @if (IsOpen)
        {
            <div class="border-t border-subtle bg-elevated p-md">

                @if (!string.IsNullOrEmpty(Stage.MasteryExpectation))
                {
                    <div class="mb-md p-sm bg-surface rounded-lg border-l-4 border-accent">
                        <span class="text-xs font-semibold text-secondary uppercase block mb-xs">Expectativa de Mestria</span>
                        <p class="text-sm text-primary m-0">@Stage.MasteryExpectation</p>
                    </div>
                }

                <div class="roadmap-stage-blocks @(UseSplitLayout ? "split" : string.Empty)">
                    @for (var index = 0; index < OrderedBlocks.Count; index++)
                    {
                        var block = OrderedBlocks[index];
                        <div class="roadmap-stage-block @(UseSplitLayout ? (index == 0 ? "left" : "right") : string.Empty)">
                            <h4 class="text-sm font-bold text-primary mb-xs">@block.Title</h4>
                            <p class="text-xs text-secondary mb-sm">@block.Description</p>

                            <div class="space-y-xs">
                                @foreach (var item in block.Items)
                                {
                                    <label class="flex items-start gap-sm p-sm rounded-lg hover:bg-surface cursor-pointer border border-transparent hover:border-subtle transition-all">
                                        <input type="checkbox" class="mt-1 accent-accent" checked="@item.IsCompleted" @onchange="(e) => ToggleItem(item, e)" />
                                        <span class="text-sm @(item.IsCompleted ? "text-tertiary line-through" : "text-primary")">@item.Description</span>
                                    </label>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public studyhub.domain.Entities.RoadmapStage Stage { get; set; } = new();
    [Parameter] public EventCallback OnProgressChanged { get; set; }

    private bool IsOpen = false;

    private IReadOnlyList<RoadmapBlock> OrderedBlocks
        => Stage.Blocks
            .OrderBy(block => IsMiniProjectBlock(block) ? 1 : 0)
            .ToList();

    private bool UseSplitLayout => OrderedBlocks.Count == 2;

    private void ToggleAccordion()
    {
        IsOpen = !IsOpen;
    }

    private async Task ToggleItem(RoadmapChecklistItem item, ChangeEventArgs e)
    {
        item.IsCompleted = (bool)(e.Value ?? false);
        await OnProgressChanged.InvokeAsync();
    }

    private string GetBorderClass()
    {
        if (Stage.Progress == 100) return "border-success";
        if (Stage.Progress > 0) return "border-accent";
        return "border-subtle";
    }

    private static bool IsMiniProjectBlock(RoadmapBlock block)
        => block.Title.Contains("Mini projeto", StringComparison.OrdinalIgnoreCase);
}
