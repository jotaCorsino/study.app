<div class="breadcrumb">
    @for (int i = 0; i < Items.Count; i++)
    {
        var item = Items[i];
        if (i > 0)
        {
            <span class="breadcrumb-separator">/</span>
        }
        
        if (i == Items.Count - 1 || string.IsNullOrEmpty(item.Url))
        {
            <span class="breadcrumb-item breadcrumb-current">@item.Text</span>
        }
        else
        {
            <a href="@item.Url" class="breadcrumb-item">@item.Text</a>
        }
    }
</div>

@code {
    [Parameter]
    public List<BreadcrumbItem> Items { get; set; } = new();

    public class BreadcrumbItem
    {
        public string Text { get; set; } = "";
        public string Url { get; set; } = "";

        public BreadcrumbItem() { }
        
        public BreadcrumbItem(string text, string url = "")
        {
            Text = text;
            Url = url;
        }
    }
}
